{
    "name": "p3a/helpdesk",
    "description": "P3A Helpdesk — security-hardened PHP support desk (port of the SupportDesk GAS prototype)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-fileinfo": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-gd": "*",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "php tests/run_all.php",
        "static": "php tests/StaticSuite.php"
    }
}
